# Local runtime environment variables configuration / 本地运行环境变量配置示例

# Device selection: cuda (GPU) or cpu / 设备选择: cuda (GPU) 或 cpu
WHISPER_DEVICE=cuda

# Compute type: GPU use float16/bfloat16, CPU use int8 / 计算类型: GPU 用 float16/bfloat16，CPU 用 int8
WHISPER_COMPUTE_TYPE=float16

# CPU threads (CPU mode only) / CPU 线程数 (仅 CPU 模式)
WHISPER_THREADS=8

# Default model / 默认模型
WHISPER_MODEL=small

# Idle timeout (seconds), 0=never unload, 600=10min / 空闲超时时间（秒），0=永不卸载，600=10分钟
WHISPER_IDLE_TIMEOUT=600

# Model cache directory / 模型缓存目录
WHISPER_CACHE_DIR=/home/abel-chen/.local/opt/fasterwhisper/whisper-models

# HuggingFace offline mode / HuggingFace 离线模式:
# - 0 = Fully online (check updates every time) / 完全在线（每次检查更新）
# - 1 = Fully offline (error if not found locally) / 完全离线（本地没有就报错）
# - auto = Smart mode (recommended: use local if exists, download if not) / 智能模式（推荐：本地有就用本地，没有就下载）
HF_HUB_OFFLINE=auto
