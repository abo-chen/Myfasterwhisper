# 本地运行环境变量配置示例

# 设备选择: cuda (GPU) 或 cpu
WHISPER_DEVICE=cuda

# 计算类型: GPU 用 float16/bfloat16，CPU 用 int8
WHISPER_COMPUTE_TYPE=float16

# CPU 线程数 (仅 CPU 模式)
WHISPER_THREADS=8

# 默认模型
WHISPER_MODEL=small

# 空闲超时时间（秒），0=永不卸载，600=10分钟
WHISPER_IDLE_TIMEOUT=600

# 模型缓存目录
WHISPER_CACHE_DIR=/home/abel-chen/.local/opt/fasterwhisper/whisper-models

# HuggingFace 离线模式: 1=离线(默认，不检查更新)，0=在线(允许检查更新)
HF_HUB_OFFLINE=1
